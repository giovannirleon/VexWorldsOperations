{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash -lc 'if [ -f .env ]; then exec node --env-file=.env --watch src/index.js; else exec node --watch src/index.js; fi'",
    "start": "node --env-file-if-exists=.env src/index.js",
    "migrate": "node --env-file-if-exists=.env scripts/migrate.js",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "pg": "^8.13.1"
  }
}
